<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/scouter_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="4dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingStart="10dp"
    android:paddingTop="9dp"
    android:paddingEnd="10dp"
    android:paddingBottom="9dp"
    android:background="@drawable/scouter_widget_bg">

    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_status_dot"
        android:layout_width="12dp"
        android:layout_height="12dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:ellipsize="middle"
        android:singleLine="true"
        android:text="Scouter"
        android:textColor="#F4FFF4"
        android:textSize="15sp"
        android:typeface="monospace"
        android:textStyle="bold" />

      <TextView
        android:id="@+id/scouter_source_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/scouter_badge_bg"
        android:paddingStart="7dp"
        android:paddingEnd="7dp"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:text="SH"
        android:textColor="#001200"
        android:textSize="11sp"
        android:typeface="monospace"
        android:textStyle="bold" />
    </LinearLayout>

    <TextView
      android:id="@+id/scouter_detail"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="7dp"
      android:ellipsize="middle"
      android:singleLine="true"
      android:text="No agent session yet"
      android:textColor="#7DDB7D"
      android:textSize="14sp"
      android:typeface="monospace"
      android:textStyle="bold" />

    <TextView
      android:layout_width="match_parent"
      android:layout_height="1dp"
      android:layout_marginTop="7dp"
      android:layout_marginBottom="6dp"
      android:background="#66338F33"
      android:text="" />

    <TextView
      android:id="@+id/scouter_metrics"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="Open Shelly to start"
      android:textColor="#9BC49B"
      android:textSize="12sp"
      android:typeface="monospace"
      android:textStyle="bold" />

    <TextView
      android:id="@+id/scouter_usage"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="3dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text=""
      android:textColor="#7A967A"
      android:textSize="11sp"
      android:typeface="monospace"
      android:textStyle="bold" />
  </LinearLayout>
</FrameLayout>
