<?xml version="1.0" encoding="utf-8"?>
<!-- Agent-launcher redesign (2026-07-18, design review): the widget's job is
     now "launch pad + health status" for up to 3 nearest-upcoming scheduled
     agents, not a Codex/local-LLM session monitor. All Codex-session detail
     (title/badge/detail/doing/conversation/metrics/usage/timer), the
     approval + interactive-choice pills, the LOCAL LLM block, and the footer
     timestamp were removed from this layout — see
     docs/superpowers/DEFERRED.md ("widget Codex/local-LLM monitor removed")
     for why and for the deferred notification-based follow-up. The pet
     ImageView is KEPT (brand/charm value) but is now purely decorative: no
     click target, moved into the header. Deep-green HUD chrome, transparent
     "smoke" background card, monospace type are all preserved from the prior
     design. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/scouter_widget_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="2dp">

  <FrameLayout
    android:id="@+id/scouter_widget_card_layer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:paddingStart="14dp"
    android:paddingTop="10dp"
    android:paddingEnd="14dp"
    android:paddingBottom="10dp"
    android:background="@drawable/scouter_widget_bg">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_gravity="top"
    android:orientation="vertical">

    <!-- ── Header: overall status dot + title + failure count + pet ── -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:gravity="center_vertical"
      android:orientation="horizontal">

      <ImageView
        android:id="@+id/scouter_header_dot"
        android:layout_width="10dp"
        android:layout_height="10dp"
        android:src="@drawable/scouter_status_dot"
        android:contentDescription="@string/scouter_status_dot" />

      <TextView
        android:id="@+id/scouter_header_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:ellipsize="end"
        android:singleLine="true"
        android:text="@string/scouter_widget_header_title"
        android:textColor="#00FF41"
        android:textSize="15sp"
        android:letterSpacing="0.06"
        android:typeface="monospace"
        android:textStyle="bold"
        android:shadowColor="#B300FF41"
        android:shadowRadius="7"
        android:includeFontPadding="false" />

      <!-- Failure count, e.g. "1 FAILED" — hidden unless a shown agent's
           last run errored. -->
      <TextView
        android:id="@+id/scouter_header_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text=""
        android:textColor="#FF4C4C"
        android:textSize="11sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false"
        android:visibility="gone" />

      <!-- Pet mascot: decorative only (no click target), kept per product
           owner's explicit charm-value override. Small, in-header. -->
      <ImageView
        android:id="@+id/scouter_codex_pet"
        android:layout_width="28dp"
        android:layout_height="30dp"
        android:layout_marginStart="8dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/scouter_codex_pet"
        android:scaleType="fitCenter"
        android:visibility="gone" />
    </LinearLayout>

    <!-- ── Agent rows (up to 3), fixed slots shown/hidden per-render.
         RemoteViews has no dynamic list adapter without RemoteViewsService
         (not used elsewhere in this app for a widget-like surface — none
         found), so 3 fixed rows is the simplest correct approach, matching
         the existing visibility="gone" pattern this file already used for
         scouter_agent_run. ── -->
    <LinearLayout
      android:id="@+id/scouter_agent_row_1"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="9dp"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:visibility="gone">

      <TextView
        android:id="@+id/scouter_agent_row_1_glyph"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="#00FF41"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/scouter_agent_row_1_name"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#00FF41"
          android:textSize="13sp"
          android:typeface="monospace"
          android:textStyle="bold"
          android:includeFontPadding="false" />

        <TextView
          android:id="@+id/scouter_agent_row_1_next"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#66FF88"
          android:textSize="10sp"
          android:typeface="monospace"
          android:includeFontPadding="false" />
      </LinearLayout>

      <TextView
        android:id="@+id/scouter_agent_row_1_run"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:minWidth="44dp"
        android:minHeight="28dp"
        android:background="@drawable/scouter_ask_pill_bg"
        android:contentDescription="@string/scouter_widget_agent_run"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="@string/scouter_widget_agent_row_run"
        android:textColor="#00FF41"
        android:textSize="11sp"
        android:letterSpacing="0.04"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/scouter_agent_row_2"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="7dp"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:visibility="gone">

      <TextView
        android:id="@+id/scouter_agent_row_2_glyph"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="#00FF41"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/scouter_agent_row_2_name"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#00FF41"
          android:textSize="13sp"
          android:typeface="monospace"
          android:textStyle="bold"
          android:includeFontPadding="false" />

        <TextView
          android:id="@+id/scouter_agent_row_2_next"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#66FF88"
          android:textSize="10sp"
          android:typeface="monospace"
          android:includeFontPadding="false" />
      </LinearLayout>

      <TextView
        android:id="@+id/scouter_agent_row_2_run"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:minWidth="44dp"
        android:minHeight="28dp"
        android:background="@drawable/scouter_ask_pill_bg"
        android:contentDescription="@string/scouter_widget_agent_run"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="@string/scouter_widget_agent_row_run"
        android:textColor="#00FF41"
        android:textSize="11sp"
        android:letterSpacing="0.04"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <LinearLayout
      android:id="@+id/scouter_agent_row_3"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="7dp"
      android:gravity="center_vertical"
      android:orientation="horizontal"
      android:visibility="gone">

      <TextView
        android:id="@+id/scouter_agent_row_3_glyph"
        android:layout_width="20dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text=""
        android:textColor="#00FF41"
        android:textSize="14sp"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />

      <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
          android:id="@+id/scouter_agent_row_3_name"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#00FF41"
          android:textSize="13sp"
          android:typeface="monospace"
          android:textStyle="bold"
          android:includeFontPadding="false" />

        <TextView
          android:id="@+id/scouter_agent_row_3_next"
          android:layout_width="match_parent"
          android:layout_height="wrap_content"
          android:ellipsize="end"
          android:singleLine="true"
          android:text=""
          android:textColor="#66FF88"
          android:textSize="10sp"
          android:typeface="monospace"
          android:includeFontPadding="false" />
      </LinearLayout>

      <TextView
        android:id="@+id/scouter_agent_row_3_run"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:gravity="center"
        android:minWidth="44dp"
        android:minHeight="28dp"
        android:background="@drawable/scouter_ask_pill_bg"
        android:contentDescription="@string/scouter_widget_agent_run"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="@string/scouter_widget_agent_row_run"
        android:textColor="#00FF41"
        android:textSize="11sp"
        android:letterSpacing="0.04"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>

    <!-- Empty state: shown only when zero enabled/scheduled agents exist. -->
    <TextView
      android:id="@+id/scouter_agent_empty"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="9dp"
      android:ellipsize="end"
      android:singleLine="true"
      android:text="@string/scouter_widget_agent_empty_state"
      android:textColor="#66FF88"
      android:textSize="12sp"
      android:typeface="monospace"
      android:includeFontPadding="false"
      android:visibility="gone" />

    <!-- ASK pill: demoted from a full-width primary action to a small
         secondary pill, right-aligned. Same id + same PendingIntent target
         as before (open Agent Chat) — visual prominence only, no behavior
         change. -->
    <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:layout_marginTop="10dp"
      android:gravity="end"
      android:orientation="horizontal">

      <TextView
        android:id="@+id/scouter_codex_ask"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:minHeight="26dp"
        android:background="@drawable/scouter_ask_pill_bg"
        android:contentDescription="@string/scouter_ask_agent_chat"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:text="@string/scouter_ask_agent_chat_short"
        android:textColor="#66FF88"
        android:textSize="11sp"
        android:letterSpacing="0.04"
        android:typeface="monospace"
        android:textStyle="bold"
        android:includeFontPadding="false" />
    </LinearLayout>
  </LinearLayout>
  </FrameLayout>
</FrameLayout>
