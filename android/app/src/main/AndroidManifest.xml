<manifest xmlns:android="http://schemas.android.com/apk/res/android" xmlns:tools="http://schemas.android.com/tools">
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"/>
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE"/>
  <uses-permission android:name="android.permission.INTERNET"/>
  <!-- bug #92: MANAGE_EXTERNAL_STORAGE gives the terminal direct read/write
       access to /sdcard so scripts pushed via `adb push /sdcard/Download` can
       be sourced from the shell. Distributed via GitHub Releases / F-Droid
       (not Play Store) so the all-files-access audit does not apply. -->
  <uses-permission android:name="android.permission.MANAGE_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.MODIFY_AUDIO_SETTINGS"/>
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
  <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"/>
  <uses-permission android:name="android.permission.RECORD_AUDIO"/>
  <!-- L1 boot-autostart (BOOT-AUTOSTART floor, flag-OFF): re-arm scheduled agents
       after reboot; request Doze exemption so unattended fires survive. Dormant
       until the BootCompletedReceiver native enable flag is flipped. -->
  <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
  <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS"/>
  <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
  <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
  <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW"/>
  <uses-permission android:name="android.permission.VIBRATE"/>
  <uses-permission android:name="android.permission.WAKE_LOCK"/>
  <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"/>
  <queries>
    <intent>
      <action android:name="android.intent.action.VIEW"/>
      <category android:name="android.intent.category.BROWSABLE"/>
      <data android:scheme="https"/>
    </intent>
  </queries>
  <application android:name=".MainApplication" android:label="@string/app_name" android:icon="@mipmap/ic_launcher" android:roundIcon="@mipmap/ic_launcher_round" android:allowBackup="false" android:theme="@style/AppTheme" android:supportsRtl="true" android:enableOnBackInvokedCallback="false" android:networkSecurityConfig="@xml/network_security_config" android:largeHeap="true" android:extractNativeLibs="true" tools:replace="android:extractNativeLibs">
    <meta-data android:name="expo.modules.updates.ENABLED" android:value="false"/>
    <meta-data android:name="expo.modules.updates.EXPO_RUNTIME_VERSION" android:value="@string/expo_runtime_version"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_CHECK_ON_LAUNCH" android:value="ALWAYS"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATES_LAUNCH_WAIT_MS" android:value="3000"/>
    <meta-data android:name="expo.modules.updates.EXPO_UPDATE_URL" android:value="https://u.expo.dev/e0d124cb-e18f-46c4-aca2-e19e48ba04fc"/>
    <service android:name="expo.modules.terminalemulator.TerminalSessionService" android:exported="false" android:foregroundServiceType="specialUse">
      <property android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE" android:value="terminal_session"/>
    </service>
    <service android:name="expo.modules.video.playbackService.ExpoVideoPlaybackService" android:exported="false" android:foregroundServiceType="mediaPlayback">
      <intent-filter>
        <action android:name="androidx.media3.session.MediaSessionService"/>
      </intent-filter>
    </service>
    <activity android:name=".MainActivity" android:configChanges="keyboard|keyboardHidden|orientation|screenSize|screenLayout|uiMode|locale|layoutDirection|smallestScreenSize|density" android:launchMode="singleTask" android:windowSoftInputMode="adjustResize" android:theme="@style/Theme.App.SplashScreen" android:exported="true" android:screenOrientation="unspecified" android:supportsPictureInPicture="true" android:resizeableActivity="true">
      <intent-filter>
        <action android:name="android.intent.action.MAIN"/>
        <category android:name="android.intent.category.LAUNCHER"/>
      </intent-filter>
      <intent-filter>
        <action android:name="android.intent.action.VIEW"/>
        <category android:name="android.intent.category.DEFAULT"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <data android:scheme="shelly"/>
        <data android:scheme="exp+shelly-terminal"/>
      </intent-filter>
      <intent-filter android:autoVerify="true" data-generated="true">
        <action android:name="android.intent.action.VIEW"/>
        <data android:scheme="shelly" android:host="*"/>
        <category android:name="android.intent.category.BROWSABLE"/>
        <category android:name="android.intent.category.DEFAULT"/>
      </intent-filter>
    </activity>
    <provider android:name="androidx.core.content.FileProvider" android:authorities="dev.shelly.terminal.shelly.fileprovider" android:exported="false" android:grantUriPermissions="true">
      <meta-data android:name="android.support.FILE_PROVIDER_PATHS" android:resource="@xml/shelly_file_provider_paths"/>
    </provider>
    <receiver android:name="expo.modules.terminalemulator.AgentAlarmReceiver" android:exported="false"/>
    <!-- L1 boot-autostart: re-arms scheduled-agent alarms after a reboot (they are
         cleared by the OS). exported=true is required to receive the system
         BOOT_COMPLETED broadcast. Dormant until the native enable flag is set. -->
    <receiver android:name="expo.modules.terminalemulator.BootCompletedReceiver" android:exported="true" android:permission="android.permission.RECEIVE_BOOT_COMPLETED">
      <intent-filter>
        <!-- BOOT_COMPLETED only: it is an AOSP protected broadcast (system-sender
             only). QUICKBOOT_POWERON is NOT protected (a normal-permission holder
             could spoof it), and LOCKED_BOOT_COMPLETED requires directBootAware
             (which would break MODE_PRIVATE prefs pre-unlock) — both omitted. -->
        <action android:name="android.intent.action.BOOT_COMPLETED"/>
      </intent-filter>
    </receiver>
    <!-- NOTIFY-001 Increment 0 (dormant, plumbing-only — see
         ShellyNotificationListener.notificationListenerEnabled, default false).
         This hand-written copy is for readability only; the copy that actually
         survives a prebuild wipe is the one registered by
         plugins/with-terminal-service.js (see the CI-prebuild-wipe lesson in
         that file's header comment) — do not rely on this block alone.
         exported=false, matching Android's own official
         NotificationListenerService declaration pattern.
         android:permission on a <service> is a DIFFERENT mechanism than the
         receiver-level android:permission mistake fixed for
         BootCompletedReceiver above: here it restricts who may BIND to this
         service, independent of exported, and BIND_NOTIFICATION_LISTENER_SERVICE
         is a system-signature permission only the OS holds. No <uses-permission>
         is needed: the actual grant is the user manually enabling this listener
         under Settings > Notification access (Settings.Secure.ENABLED_NOTIFICATION_LISTENERS),
         not a manifest permission. -->
    <service android:name="expo.modules.terminalemulator.ShellyNotificationListener" android:exported="false" android:permission="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE">
      <intent-filter>
        <action android:name="android.service.notification.NotificationListenerService"/>
      </intent-filter>
    </service>
  </application>
</manifest>
